{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "OpenOCD attach (symbols only; never program)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "executable": "build/tinySA4.elf",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f3x.cfg"
            ],
            "cwd": "${workspaceRoot}",
            "device": "stm32f303",
            "preLaunchTask": "build"
        },
        {
            "name": "ST-Link attach (symbols only; never program)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "stutil",
            "executable": "build/tinySA4.elf",
            "cwd": "${workspaceRoot}",
            "device": "stm32f303",
            "preLaunchTask": "build"
        }
    ]
}
