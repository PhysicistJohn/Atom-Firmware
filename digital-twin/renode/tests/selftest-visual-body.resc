# This scenario is included after zs407.resc by the visual-regression runner.
# The runner supplies $captureDir and, for relocatable builds, installs the
# matching SRAM symbol profile before this file is evaluated.
# Each frame is taken from the positive-argument interactive result screen,
# before modeled touch acknowledgement restores normal sweeping.

emulation RunFor "1.5"
twinStatus AssertBooted
twinStatus SetCalibrationLoopback 1 -35.3

twinStatus RunInteractiveSelfTestCase 1
emulation RunFor "5.00"
twinStatus AssertInteractiveSelfTestCase 1 1
twinStatus ReportSelfTestCase 1
spi1.spiFabric.lcd SaveScreenshot $captureDir/case-01.png
twinStatus SaveScreenRaw $captureDir/case-01.rgb565
adc2 SetTouchPixel 200 150
emulation RunFor "1.50"
adc2 ReleaseTouch
emulation RunFor "0.10"
twinStatus AssertSelfTestCase 1 1

twinStatus RunInteractiveSelfTestCase 2
emulation RunFor "5.00"
twinStatus AssertInteractiveSelfTestCase 2 1
