include $ORIGIN/../zs407.resc

emulation RunFor "1.5"
twinStatus AssertBooted

# Bus reset and the standard control transfers are injected by the host
# fixture. Descriptor bytes and controller state still come from firmware.
usb HostReset
emulation RunFor "0.05"
usb AssertDevice 0 0

usb ClearCapture
usb HostSetup "8006000100001200"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.02"
usb HostOut 0 ""
emulation RunFor "0.02"
usb AssertCaptureHexContains "120110010200004083044057"

usb HostSetup "0005010000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.02"
usb AssertDevice 1 0

usb ClearCapture
usb HostSetup "8006000200004300"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.02"
usb HostOut 0 ""
emulation RunFor "0.02"
usb AssertCaptureHexContains "09024300020100c032"

usb HostSetup "0009010000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.05"
usb AssertDevice 1 1
usb AssertActiveBufferAddressesDistinct

# Hosts may select the active configuration again. This exercises endpoint
# teardown/rebuild and guards EP0's packet-memory buffers against reuse by the
# CDC data endpoints.
usb HostSetup "0009010000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.05"
usb AssertDevice 1 1
usb AssertActiveBufferAddressesDistinct

# Unconfigure and select configuration 1 again. This is a distinct allocator
# path and must not depend on the same-value compatibility behavior above.
usb HostSetup "0009000000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.05"
usb AssertDevice 1 0
usb AssertActiveBufferAddressesDistinct
usb HostSetup "0009010000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.05"
usb AssertDevice 1 1
usb AssertActiveBufferAddressesDistinct

# Complete the CDC ACM host handshake (115200 8N1, DTR + RTS).
usb HostSetup "2120000000000700"
emulation RunFor "0.02"
usb HostOut 0 "00c20100000008"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.02"
usb HostSetup "2122030000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "1.20"

# Exercise the real CDC queues and shell parser with a fragmented command.
usb ClearCapture
usb HostOut 1 "766572"
emulation RunFor "0.03"
usb HostOut 1 "73696f6e0d"
emulation RunFor "0.20"
usb HostSof 1
emulation RunFor "0.02"
usb HostPollIn 1
emulation RunFor "0.02"
usb HostSof 1
emulation RunFor "0.02"
usb HostPollIn 1
emulation RunFor "0.02"
usb HostSof 1
emulation RunFor "0.02"
usb HostPollIn 1
emulation RunFor "0.02"
usb HostSof 1
emulation RunFor "0.02"
usb HostPollIn 1
emulation RunFor "0.02"
twinStatus ReportShell
usb Report
usb AssertCaptureContains "tinySA4"
usb AssertCaptureContains "ch> "

# Suspend/wakeup and an unsupported descriptor request exercise global-event
# IRQs, EP0 STALL behavior, then bus-reset recovery and re-enumeration.
usb HostSuspend
emulation RunFor "0.05"
usb HostWakeup
emulation RunFor "0.05"
usb AssertEvents 1 1 1
usb HostSetup "8006ff7f00000100"
emulation RunFor "0.05"
usb AssertEndpointStalled 0

usb HostReset
emulation RunFor "0.05"
usb HostSetup "0005010000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.02"
usb HostSetup "0009010000000000"
emulation RunFor "0.02"
usb HostIn 0
emulation RunFor "0.05"
usb AssertDevice 1 1
usb AssertEvents 2 1 1

twinStatus Report
quit
