+// Full license text is available in 'licenses/MIT.txt'.
+//
+
+using Antmicro.Renode.Core;
+using Antmicro.Renode.Peripherals.IRQControllers;
+
+using NUnit.Framework;
+
+namespace Antmicro.Renode.UnitTests
+{
+    [TestFixture]
+    public class NVICTests
+    {
+        [Test]
+        public void ShouldReportReturnToBaseWhenNoExceptionIsActive()
+        {
+            using(var machine = new Machine())
+            {
+                var nvic = new NVIC(machine);
+
+                Assert.That(nvic.ReadDoubleWord(InterruptControlState) & ReturnToBase,
+                    Is.EqualTo(ReturnToBase));
+            }
+        }
+
+        private const long InterruptControlState = 0xD04;
+        private const uint ReturnToBase = 1u << 11;
+    }
+}
