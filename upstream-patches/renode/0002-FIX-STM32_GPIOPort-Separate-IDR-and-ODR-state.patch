From: PhysicistJohn <54456354+PhysicistJohn@users.noreply.github.com>
Date: Sat, 11 Jul 2026 12:15:49 -0700
Subject: [PATCH] [FIX] STM32_GPIOPort: Separate IDR and ODR state

---
 .../Peripherals/GPIOPort/STM32_GPIOPort.cs    | 28 +++++++--
 .../PeripheralsTests/STM32_GPIOPortTests.cs   | 58 +++++++++++++++++++
 2 files changed, 80 insertions(+), 6 deletions(-)
 create mode 100644 src/Emulator/Peripherals/Test/PeripheralsTests/STM32_GPIOPortTests.cs

diff --git a/src/Emulator/Peripherals/Peripherals/GPIOPort/STM32_GPIOPort.cs b/src/Emulator/Peripherals/Peripherals/GPIOPort/STM32_GPIOPort.cs
index 26737143..b2bfb0cf 100644
--- a/src/Emulator/Peripherals/Peripherals/GPIOPort/STM32_GPIOPort.cs
+++ b/src/Emulator/Peripherals/Peripherals/GPIOPort/STM32_GPIOPort.cs
@@ -61,6 +61,7 @@ public STM32_GPIOPort(IMachine machine, uint modeResetValue = 0, uint outputSpee
             mode = new Mode[NumberOfPins];
             outputSpeed = new OutputSpeed[NumberOfPins];
             pullUpPullDown = new PullUpPullDown[NumberOfPins];
+            outputState = new bool[NumberOfPins];
 
             this.modeResetValue = modeResetValue;
             this.outputSpeedResetValue = outputSpeedResetValue;
@@ -84,6 +85,7 @@ public override void Reset()
 
             lockedPins = 0;
             lockSequenceState = LockSequence.Idle;
+            Array.Clear(outputState, 0, outputState.Length);
 
             for(var i = 0; i < NumberOfPins; i++)
             {
@@ -127,12 +129,21 @@ private void WritePin(int number, bool value)
             Connections[number].Set(value);
         }
 
-        private void WriteState(ushort value)
+        private void WriteOutputPin(int number, bool value)
+        {
+            outputState[number] = value;
+            if(mode[number] == Mode.Output)
+            {
+                WritePin(number, value);
+            }
+        }
+
+        private void WriteOutputState(ushort value)
         {
             for(var i = 0; i < NumberOfPins; i++)
             {
                 var state = ((value & 1u) == 1);
-                WritePin(i, state);
+                WriteOutputPin(i, state);
 
                 value >>= 1;
             }
@@ -142,6 +153,10 @@ private void ChangeMode(int number, Mode newMode)
         {
             mode[number] = newMode;
             alternateFunctionOutputs[number].IsConnected = newMode == Mode.AlternateFunction;
+            if(newMode == Mode.Output)
+            {
+                WritePin(number, outputState[number]);
+            }
         }
 
         private void GuardPinAction(int number, string name, Action action)
@@ -197,15 +212,15 @@ private DoubleWordRegisterCollection CreateRegisters()
                     .WithReservedBits(16, 16)
                 },
                 {(long)Registers.OutputData, new DoubleWordRegister(this)
-                    .WithValueField(0, 16, writeCallback: (_, val) => WriteState((ushort)val), valueProviderCallback: _ => BitHelper.GetValueFromBitsArray(State), name: "ODR")
+                    .WithValueField(0, 16, writeCallback: (_, val) => WriteOutputState((ushort)val), valueProviderCallback: _ => BitHelper.GetValueFromBitsArray(outputState), name: "ODR")
                     .WithReservedBits(16, 16)
                 },
                 {(long)Registers.BitSet, new DoubleWordRegister(this)
                     .WithValueField(0, 16, FieldMode.Write,
-                        writeCallback: (_, val) => { if(val != 0) WriteState((ushort)(BitHelper.GetValueFromBitsArray(State) | val)); },
+                        writeCallback: (_, val) => { if(val != 0) WriteOutputState((ushort)(BitHelper.GetValueFromBitsArray(outputState) | val)); },
                         name: "GPIOx_BS")
                     .WithValueField(16, 16, FieldMode.Write,
-                        writeCallback: (_, val) => { if(val != 0) WriteState((ushort)(BitHelper.GetValueFromBitsArray(State) & ~val)); },
+                        writeCallback: (_, val) => { if(val != 0) WriteOutputState((ushort)(BitHelper.GetValueFromBitsArray(outputState) & ~val)); },
                         name: "GPIOx_BR")
                 },
                 { (long)Registers.ConfigurationLock, new DoubleWordRegister(this)
@@ -278,7 +293,7 @@ private DoubleWordRegisterCollection CreateRegisters()
                 },
                 {(long)Registers.BitReset, new DoubleWordRegister(this)
                     .WithValueField(0, 16, FieldMode.Write,
-                        writeCallback: (_, val) => { if(val != 0) WriteState((ushort)(BitHelper.GetValueFromBitsArray(State) & ~val)); },
+                        writeCallback: (_, val) => { if(val != 0) WriteOutputState((ushort)(BitHelper.GetValueFromBitsArray(outputState) & ~val)); },
                         name: "GPIOx_BRR")
                     .WithReservedBits(16, 16)
                 },
@@ -292,6 +307,7 @@ private DoubleWordRegisterCollection CreateRegisters()
         private readonly Mode[] mode;
         private readonly OutputSpeed[] outputSpeed;
         private readonly PullUpPullDown[] pullUpPullDown;
+        private readonly bool[] outputState;
         private readonly HashSet<InvertedAFPin> invertedAFPins = new HashSet<InvertedAFPin>();
 
         private readonly uint modeResetValue;
diff --git a/src/Emulator/Peripherals/Test/PeripheralsTests/STM32_GPIOPortTests.cs b/src/Emulator/Peripherals/Test/PeripheralsTests/STM32_GPIOPortTests.cs
new file mode 100644
index 00000000..11ddaa33
--- /dev/null
+++ b/src/Emulator/Peripherals/Test/PeripheralsTests/STM32_GPIOPortTests.cs
@@ -0,0 +1,58 @@
