mach create "cortex-m0"
machine LoadPlatformDescriptionFromString "cpu: CPU.CortexM @ sysbus { cpuType: \"cortex-m0\"; nvic: nvic }; nvic: IRQControllers.NVIC @ sysbus 0xE000E000 { -> cpu@0 }"
echo "CORTEX_M0_ICSR"
cpu ArchitectureVersion
cpu Model
sysbus ReadDoubleWord 0xE000ED04

mach create "cortex-m0-plus"
machine LoadPlatformDescriptionFromString "cpu: CPU.CortexM @ sysbus { cpuType: \"cortex-m0+\"; nvic: nvic }; nvic: IRQControllers.NVIC @ sysbus 0xE000E000 { -> cpu@0 }"
echo "CORTEX_M0_PLUS_ICSR"
cpu ArchitectureVersion
cpu Model
sysbus ReadDoubleWord 0xE000ED04

