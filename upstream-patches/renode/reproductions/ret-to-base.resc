mach create "cortex-m4"
machine LoadPlatformDescriptionFromString "cpu: CPU.CortexM @ sysbus { cpuType: \"cortex-m4\"; nvic: nvic }; nvic: IRQControllers.NVIC @ sysbus 0xE000E000 { -> cpu@0 }"
echo "CORTEX_M4_ICSR_NO_ACTIVE"
