mach create "cortex-m23"
machine LoadPlatformDescriptionFromString "cpu: CPU.CortexM @ sysbus { cpuType: \"cortex-m23\"; nvic: nvic }; nvic: IRQControllers.NVIC @ sysbus 0xE000E000 { -> cpu@0 }"
